# Required: Airtable base ID for the Research Outreach base.
AIRTABLE_BASE_ID=

# Required: Airtable personal access token with read/write access to the base.
AIRTABLE_TOKEN=

# Required: OpenAI API key used for research runs and draft generation.
OPENAI_API_KEY=

# Optional: model used with the OpenAI Responses API.
OPENAI_MODEL=gpt-5-mini

# Optional: default owner name stored on new opportunities.
RESEARCH_APP_OWNER=Owner
